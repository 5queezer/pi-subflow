{
	"name": "pi-subflow",
	"version": "0.1.0",
	"description": "PocketFlow-powered Pi subagent orchestration prototype",
	"main": "dist/index.js",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		}
	},
	"directories": {
		"doc": "doc",
		"test": "tests"
	},
	"scripts": {
		"test": "node --import tsx --test tests/*.test.ts",
		"build": "tsc -p tsconfig.json && node scripts/link-dist-deps.mjs",
		"check": "biome check .",
		"wiki:sync": "node scripts/sync-wiki.mjs",
		"wiki:sync:push": "node scripts/sync-wiki.mjs --push",
		"prepare": "husky"
	},
	"keywords": [],
	"author": "Christian Pojoni",
	"license": "ISC",
	"type": "module",
	"types": "dist/index.d.ts",
	"dependencies": {
		"@earendil-works/pi-coding-agent": "^0.74.0",
		"@earendil-works/pi-tui": "^0.74.0",
		"pocketflow": "^1.0.4",
		"typebox": "^1.1.38",
		"yaml": "^2.8.4"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.15",
		"@types/node": "^25.6.2",
		"husky": "^9.1.7",
		"tsx": "^4.20.6",
		"typescript": "^5.8.2"
	}
}
