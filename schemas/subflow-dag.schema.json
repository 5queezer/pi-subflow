{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/5queezer/pi-subflow/schemas/subflow-dag.schema.json",
  "title": "pi-subflow DAG YAML",
  "description": "YAML language-server schema for pi-subflow dagYaml workflow templates. Runtime validation still checks graph semantics such as missing dependencies, self-dependencies, duplicate names, and cycles.",
  "type": "object",
  "minProperties": 1,
  "additionalProperties": {
    "$ref": "#/$defs/task"
  },
  "$defs": {
    "stringArray": {
      "type": "array",
      "items": { "type": "string" }
    },
    "task": {
      "type": "object",
      "additionalProperties": false,
      "required": ["agent", "task"],
      "properties": {
        "agent": { "type": "string", "minLength": 1 },
        "task": { "type": "string", "minLength": 1 },
        "cwd": { "type": "string" },
        "needs": { "$ref": "#/$defs/stringArray" },
        "dependsOn": { "$ref": "#/$defs/stringArray" },
        "role": { "enum": ["worker", "verifier"] },
        "authority": { "enum": ["read_only", "internal_mutation", "external_side_effect"] },
        "tools": { "$ref": "#/$defs/stringArray" },
        "model": { "type": "string" },
        "thinking": { "enum": ["off", "minimal", "low", "medium", "high", "xhigh"] },
        "expectedSections": { "$ref": "#/$defs/stringArray" },
        "jsonSchema": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "required": { "$ref": "#/$defs/stringArray" }
          }
        }
      },
      "not": {
        "required": ["needs", "dependsOn"]
      }
    }
  }
}
