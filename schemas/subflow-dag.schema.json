{
  "title": "pi-subflow DAG YAML",
  "description": "YAML language-server schema for pi-subflow dagYaml workflow templates. Runtime validation still checks graph semantics such as missing dependencies, self-dependencies, duplicate names, and cycles.",
  "type": "object",
  "minProperties": 1,
  "additionalProperties": {
    "$ref": "#/$defs/task"
  },
  "$defs": {
    "stringArray": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "workflow": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "tasks": {
          "oneOf": [
            {
              "type": "array",
              "items": {
                "$ref": "#/$defs/task"
              }
            },
            {
              "type": "object",
              "additionalProperties": {
                "$ref": "#/$defs/task"
              }
            }
          ]
        },
        "dagYaml": {
          "type": "string"
        },
        "uses": {
          "type": "string"
        }
      },
      "not": {
        "required": [
          "tasks",
          "dagYaml"
        ]
      },
      "anyOf": [
        {
          "required": [
            "tasks"
          ]
        },
        {
          "required": [
            "dagYaml"
          ]
        },
        {
          "required": [
            "uses"
          ]
        }
      ]
    },
    "task": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "agent": {
          "type": "string",
          "minLength": 1
        },
        "task": {
          "type": "string",
          "minLength": 1
        },
        "workflow": {
          "$ref": "#/$defs/workflow"
        },
        "cwd": {
          "type": "string"
        },
        "needs": {
          "$ref": "#/$defs/stringArray"
        },
        "dependsOn": {
          "$ref": "#/$defs/stringArray"
        },
        "when": {
          "type": "string"
        },
        "role": {
          "enum": [
            "worker",
            "verifier"
          ]
        },
        "authority": {
          "enum": [
            "read_only",
            "internal_mutation",
            "external_side_effect"
          ]
        },
        "tools": {
          "$ref": "#/$defs/stringArray"
        },
        "model": {
          "type": "string"
        },
        "thinking": {
          "enum": [
            "off",
            "minimal",
            "low",
            "medium",
            "high",
            "xhigh"
          ]
        },
        "expectedSections": {
          "$ref": "#/$defs/stringArray"
        },
        "jsonSchema": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "required": {
              "$ref": "#/$defs/stringArray"
            }
          }
        }
      },
      "not": {
        "required": [
          "needs",
          "dependsOn"
        ]
      },
      "anyOf": [
        {
          "required": [
            "agent",
            "task"
          ]
        },
        {
          "required": [
            "workflow"
          ]
        }
      ]
    }
  }
}
